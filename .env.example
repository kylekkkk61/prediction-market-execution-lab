# bot_bid.py taker settings
TRADE_AMOUNT_USD=1.0
MARKET_BUCKET_MINUTES=5
EDGE_PROB_THRESHOLD=0.18
EDGE_REFERENCE_PRICE=ask
COOLDOWN_SECONDS=3
SIGNAL_COOLDOWN_SECONDS=3
MAX_SPREAD=0.02
DRY_RUN=true

# bot_bid.py dual-sigma model settings
VOL_WINDOW_SHORT_SECONDS=20
VOL_WINDOW_LONG_SECONDS=80
SIGMA_SHORT_WEIGHT=0.75
SIGMA_LONG_WEIGHT=0.25
SIGMA_MIN=0.000015
TAU_FLOOR_SECONDS=5
Z_CAP=6.0
OPEN_ANCHOR_MODE=bn
OPEN_ANCHOR_WEIGHT=0
TAKER_ORDER_TYPE=FOK #FOK, FAK, market
EXEC_PRICE_MODE=hybrid #hybrid, book, edge
EXEC_SLIPPAGE_TICKS=2
MIN_EDGE_AFTER_FILL=0.24
EXEC_PRICE_CAP=0.99
MARKET_MAX_TOTAL_COST=12.0
MARKET_MAX_SIDE_COST=6.0
MIN_ENTRY_ASK_PRICE=0
MIN_ENTRY_REMAINING_SECONDS=0
ENTRY_TIME_BUCKETS=

# ML signal filter. Keep disabled until walk-forward reports prove it improves live criteria.
ML_FILTER_ENABLED=true
ML_FILTER_MODEL_PATH=models/signal_filter_lgbm_v1.txt
ML_FILTER_FEATURES_PATH=models/signal_filter_lgbm_v1_features.json
ML_FILTER_MIN_EV=0.0
ML_FILTER_FAIL_OPEN=false

# Fill probability filter
RAW_CANDIDATE_LOG_ENABLED=true
FILL_PROB_FILTER_ENABLED=true
FILL_PROB_MODEL_PATH=models/live_candidate_research_weekdays_2026-05-21_30/fill_probability_model.txt
FILL_PROB_FEATURES_PATH=models/live_candidate_research_weekdays_2026-05-21_30/features.json
FILL_PROB_MIN_PROBABILITY=0.70
FILL_PROB_FAIL_OPEN=false

# Side extension settings (taking more after an initial fill if the edge is good)
SIDE_EXTENSION_ENABLED=true
SIDE_EXTENSION_START_COST=6.0
SIDE_EXTENSION_MAX_SIDE_COST=9.0
SIDE_EXTENSION_MIN_SECONDS=20
SIDE_EXTENSION_COOLDOWN_SECONDS=15
SIDE_EXTENSION_MIN_EDGE=0.20
SIDE_EXTENSION_MIN_EDGE_AFTER_FILL=0.18
SIDE_EXTENSION_MIN_ASK_PRICE=0.40
SIDE_EXTENSION_MAX_ASK_PRICE=0.80
SIDE_EXTENSION_MAX_OPPOSITE_COST=1.0

# Tail reversal cooldown risk overlay
TAIL_REVERSAL_COOLDOWN_ENABLED=false
TAIL_REVERSAL_LOOKBACK_SECONDS=5400
TAIL_REVERSAL_TRIGGER_COUNT=2
TAIL_REVERSAL_COOLDOWN_SECONDS=1800
TAIL_REVERSAL_ANCHOR_SECONDS=30
TAIL_REVERSAL_CONFIRM_SECONDS=5
TAIL_REVERSAL_MIN_ANCHOR_PROB=0.55
TAIL_REVERSAL_MIN_PROB_DROP=0.10
TAIL_REVERSAL_MIN_MID_GAIN=0.03

# Signing wallet (your MetaMask EOA private key)
PRIVATE_KEY=

# Wallet shown in Polymarket settings; for MetaMask browser-wallet setups this is usually the SAFE wallet
FUNDER_ADDRESS=
POLY_SIGNATURE_TYPE=2
CLAIM_RELAYER_TX_TYPE=SAFE

# Relayer API key from Polymarket Settings > API Keys
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=
RELAYER_URL=https://relayer-v2.polymarket.com

# V2 CLOB / collateral
CLOB_HOST=https://clob.polymarket.com
CLAIM_COLLATERAL_TOKEN=pusd
CLAIM_REDEEM_TARGET=ctf_collateral_adapter

# Paths
LEDGER_DIR=ledger
CLAIM_STATE_PATH=ledger/claim_state.json

# Polling / scan settings
CLAIM_GAS_LIMIT=500000
CLAIM_POLL_INTERVAL_SECONDS=2
CLAIM_POLL_TIMEOUT_SECONDS=120
CLAIM_SCAN_INTERVAL_SECONDS=20

# logging
SHOW_BN_TICK_LOG=false
SHOW_PM_QUOTE_LOG=false
SHOW_LEDGER_SNAPSHOT_LOG=true

# Tick snapshots for offline replay/backtesting
TICK_SNAPSHOT_ENABLED=true
TICK_SNAPSHOT_MODE=both
TICK_SNAPSHOT_MIN_INTERVAL_MS=250
TICK_SNAPSHOT_INTERVAL_SECONDS=3
TICK_SNAPSHOT_DIR=tick_snapshots
