# Demo-only environment variables for public research workflows.
# Do not place private keys, wallet credentials, exchange credentials, or live execution secrets in this file.

# Optional local paths
DATA_DIR=data/sample
REPORTS_DIR=reports
FIGURES_DIR=reports/figures

# Optional public/read-only endpoints can be configured here if needed.
POLYMARKET_DATA_BASE_URL=https://clob.polymarket.com
BTC_REFERENCE_SYMBOL=BTCUSDT

# Runtime mode should remain research/demo-oriented in the public repository.
APP_ENV=development
RUN_MODE=research
