# Demo-safe environment variables for public research workflows.
# Do not place real API keys, wallet keys, or production credentials in this file.

PROJECT_ENV=development
LOG_LEVEL=INFO

# Optional public market data endpoints or local sample paths.
BTC_REFERENCE_SYMBOL=BTCUSDT
SAMPLE_DATA_DIR=data/sample
REPORT_OUTPUT_DIR=reports

# Reserved for future read-only data collection demos.
# Do not add private execution credentials here.
POLYMARKET_READ_ONLY_MODE=true
